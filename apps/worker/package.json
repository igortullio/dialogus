    "@dialogus/shared": "workspace:*",
    "drizzle-orm": "^0.45.0",
    "pg-boss": "^12.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}

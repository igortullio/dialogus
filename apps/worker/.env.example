# apps/worker — environment overrides
#
# The worker process consumes the same root `.env` as the rest of the workspace
# (loaded via `loadEnvFromRoot`). The variables below are repeated here so that
# this directory's local conventions are obvious to operators running the
# worker in isolation. Copy values into the root `.env` for development, or
# inject through your deploy tooling.

# Postgres connection used for both Drizzle and pg-boss.
DATABASE_URL=postgres://dialogus:dialogus@localhost:5432/dialogus

# Runtime mode: development | production | test.
NODE_ENV=development

# pino log level: trace | debug | info | warn | error.
LOG_LEVEL=info

# OpenAI API key — used by the embed stage (text-embedding-3-small).
# Required at runtime when EMBEDDING_PROVIDER=openai or NODE_ENV=production.
OPENAI_API_KEY=

# Anthropic API key — used by the summarize stage (claude-haiku-4-5).
# REQUIRED at runtime when SUMMARY_GENERATOR=anthropic or NODE_ENV=production.
# Without it, the worker falls back to MockChapterSummaryGenerator in dev/test.
ANTHROPIC_API_KEY=

# Override the embedding provider. mock | openai. Defaults to mock outside production.
# EMBEDDING_PROVIDER=

# Override the chapter-summary generator. mock | anthropic. Defaults to mock outside production.
# SUMMARY_GENERATOR=

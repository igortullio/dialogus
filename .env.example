# dIAlogus environment variables
# Copy this file to `.env` and fill in the values you need for local development.
# `.env` is gitignored; never commit real secrets.

DATABASE_URL=postgres://dialogus:dialogus@localhost:5432/dialogus # Feature 000 Foundation — Postgres connection string (shared by apps/api, @dialogus/db, pg-boss, @mastra/pg)
NODE_ENV=development # Feature 000 Foundation — runtime mode (development | production | test)
API_PORT=3001 # Feature 000 Foundation — Hono API listen port (apps/api)
WEB_PORT=3000 # Feature 000 Foundation — Next.js listen port (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3001 # Feature 000 Foundation — apps/web Server Components use this to reach apps/api /health
LOG_LEVEL=info # Feature 000 Foundation — pino log level (trace | debug | info | warn | error)
OPENAI_API_KEY= # Feature 002 Ingestion — OpenAI embeddings key for text-embedding-3-small
ANTHROPIC_API_KEY= # Feature 003 RAG Agent — Anthropic Claude key for dialogusAgent (haiku dev / sonnet prod)
NEXT_PUBLIC_MASTRA_URL=http://localhost:3002 # Feature 003 RAG Agent — apps/web uses this to reach the Mastra Dev Server
MASTRA_PORT=3002 # Feature 003 RAG Agent — Mastra Dev Server listen port (apps/mastra)
MASTRA_STUDIO_PORT=4111 # Feature 003 RAG Agent — Mastra Studio observability UI port
WEB_ORIGIN=http://localhost:3000 # Feature 001 Catalog — allowed CORS origin for apps/web (used by apps/api cors middleware)

# dIAlogus environment variables — copy to `.env` and fill in secrets.
# Defaults live in packages/shared/src/config; only uncomment to override.

# --- Required ---
DATABASE_URL=postgres://dialogus:dialogus@localhost:5432/dialogus
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional overrides ---
# EMBEDDING_PROVIDER=openai           # mock | openai
# SUMMARY_GENERATOR=openai            # mock | anthropic | openai
# DIALOGUS_AGENT_MODEL=gpt-4o-mini    # gpt-*/o*-* → openai; claude-* → anthropic
# DIALOGUS_AGENT_PROVIDER=openai      # only when DIALOGUS_AGENT_MODEL is unset
# OPENAI_SUMMARY_MIN_TIME_MS=21000    # OpenAI tier-0 throttle (3 RPM)
# LOG_LEVEL=info                      # trace | debug | info | warn | error

# --- Auth (feature 001-multi-user-auth) ---
# Required in production; in dev a throwaway default is used if unset.
# BETTER_AUTH_SECRET=                 # e.g. `openssl rand -base64 32`
# MASTRA_AUTH_SECRET=                 # secret Mastra uses to verify forwarded sessions
# APP_URL=http://localhost:3000       # public web base URL (invite/reset links, trusted origin)
# AUTH_TRUSTED_ORIGINS=http://localhost:3000   # comma-separated extra trusted origins
# SESSION_MAX_AGE_SECONDS=604800      # session inactivity / max age (7 days)
# AUTH_RATE_LIMIT_SIGNIN_MAX=5        # failed sign-ins per window before back-off
# INGESTION_USER_CONCURRENCY_LIMIT=2  # max simultaneous in-flight ingestions per user

# --- Ingestion progress observability (feature 002-ingestion-progress-tracking) ---
# INGESTION_STALL_THRESHOLD_MS=60000   # non-terminal idle window before a book reads as "stalled"
# INGESTION_DOWNLOAD_HEARTBEAT_MS=1000 # min interval between download progress/heartbeat writes

# --- Email (invitations + password reset) ---
# EMAIL_PROVIDER=mock                 # mock (logs the link) | resend
# RESEND_API_KEY=                     # required when EMAIL_PROVIDER=resend (or NODE_ENV=production)
# EMAIL_FROM="dIAlogus <noreply@yourdomain>"
